# Copy this file to .env and set real values locally.
OPENAI_API_KEY=

# Supabase / pgvector connection URL
# Local Docker default: postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Environment: development | staging | production
# Set to production to hide the Streamlit deploy/toolbar button
APP_ENV=development

# Observability controls (local structured logs + in-app metrics panel)
OBSERVABILITY_ENABLED=true

# --- Sentry (error tracking) ---
# Get DSN from: https://sentry.io → Project → Settings → SDK Setup
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# --- OpenTelemetry (distributed tracing → Grafana Cloud / Jaeger / Tempo) ---
# Grafana Cloud OTLP endpoint example:
#   https://otlp-gateway-prod-us-central-0.grafana.net/otlp
# Local Jaeger example: http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
# For Grafana Cloud basic auth: Authorization=Basic <base64(instanceId:apiToken)>
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=enterprise-rag

# --- Langfuse (LLM call tracing / token cost visibility) ---
# Sign up at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
