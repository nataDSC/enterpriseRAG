# Copy this file to .env and set real values locally.
OPENAI_API_KEY=

# Supabase / pgvector connection URL
# Local Docker default: postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Environment: development | staging | production
# Set to production to hide the Streamlit deploy/toolbar button
APP_ENV=development
